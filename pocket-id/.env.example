##############################################################################
# Pocket ID Docker Compose – Environment Configuration
# Copy this file to .env and fill in your values before starting.
# DO NOT commit .env to version control (it is listed in .gitignore).
##############################################################################

## ── Compose file stack ──────────────────────────────────────────────────────
COMPOSE_FILE=docker-compose.yml:external-proxy/pocket-id.yml
COMPOSE_PATH_SEPARATOR=:

## ── Network ───────────────────────────────────────────────────────────────────
# Host LAN IP — required when cloudflared runs as a Docker container so it can
# reach Pocket ID. If cloudflared runs as a system service, leave commented out
# (defaults to 127.0.0.1, binding only to localhost).
#HOST_IP=192.168.0.180

## ── Pocket ID (required) ──────────────────────────────────────────────────────
# Public URL where Pocket ID is accessible (must be HTTPS for passkeys).
APP_URL=https://pocket-id.YOUR.DOMAIN

# Encryption key for data at rest.
# Generate with: openssl rand -base64 32
# Or run: ./scripts/generate-encryption-key.sh
ENCRYPTION_KEY=

## ── Pocket ID (optional — defaults are fine for most setups) ──────────────────
# Trust the reverse proxy for X-Forwarded-* headers (default: false).
# Set true when behind Cloudflare Tunnel.
#TRUST_PROXY=true

# User signup: disabled | withToken | open (default: disabled)
# withToken = only users with an admin-generated invite link can sign up
#ALLOW_USER_SIGNUPS=withToken

# Container user/group IDs (default: 1000).
#PUID=1000
#PGID=1000

# Pocket ID data — SQLite DB and uploads live here (default: ./data).
# Linux: must be writable by PUID:PGID.
# Windows: use forward slashes (e.g. D:/pocket-id-data)
#POCKET_ID_DATA_DIR=./data
