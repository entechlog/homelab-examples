##############################################################################
# OpenCloud Docker Compose – Environment Configuration
# Copy this file to .env and fill in your values before starting.
# DO NOT commit .env to version control (it is listed in .gitignore).
##############################################################################

## ── Compose file stack ──────────────────────────────────────────────────────
COMPOSE_FILE=docker-compose.yml:external-proxy/opencloud.yml
COMPOSE_PATH_SEPARATOR=:

## ── Security / TLS ──────────────────────────────────────────────────────────
# For local testing: PROXY_TLS=true (OpenCloud serves self-signed HTTPS)
# For production with Cloudflare Tunnel: PROXY_TLS=false (Cloudflare handles TLS)
PROXY_TLS=false
INSECURE=true

## ── Network ───────────────────────────────────────────────────────────────────
# Host LAN IP — required when cloudflared runs as a Docker container so it can
# reach OpenCloud. If cloudflared runs as a system service, leave commented out
# (defaults to 127.0.0.1, binding only to localhost).
#HOST_IP=192.168.0.180

## ── OpenCloud ────────────────────────────────────────────────────────────────
# REQUIRED: Primary domain where OpenCloud is accessible.
# For local testing: OC_DOMAIN=localhost:9200
OC_DOMAIN=cloud.YOUR.DOMAIN

# REQUIRED: Admin password. Set BEFORE first start – cannot be changed via env after init.
# Must satisfy password policy (min 8 chars, upper, lower, digit, special char).
INITIAL_ADMIN_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# OpenCloud data — all user files live here. Point this to your external drive.
# Linux: must be owned by UID:GID 1000:1000 (sudo chown -R 1000:1000 /path)
# Windows: use forward slashes (e.g. D:/opencloud-data or E:/opencloud-data)
OC_DATA_DIR=/mnt/external-drive/opencloud
#OC_DATA_DIR=D:/opencloud-data

# Default storage quota per user in bytes. 50 GB = 53687091200, 0 = unlimited.
# Total service storage is controlled by the size of your OC_DATA_DIR partition/drive.
OC_DEFAULT_QUOTA=53687091200
