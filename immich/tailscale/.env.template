# Tailscale Auth Key
# Generate at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxx

# Hostname for this node on your tailnet
# Access via: https://<TS_HOSTNAME>.<tailnet-name>.ts.net
TS_HOSTNAME=immich

# Immich host IP and port
# Set this to the IP address of your machine running Immich
IMMICH_HOST=localhost
IMMICH_PORT=2283
