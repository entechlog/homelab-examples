# Immich Configuration Template
# Copy this file to .env and fill in your values
# Documentation: https://docs.immich.app/install/environment-variables

# =============================================================================
# IMMICH CORE SETTINGS
# =============================================================================

# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored
# Network shares are not supported for the database
DB_DATA_LOCATION=pgdata

# Timezone (optional) - https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York

# The Immich version to use. Pin to a specific version like "v2.1.0" for stability
IMMICH_VERSION=v2

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# Connection secret for postgres - CHANGE THIS to a random password
# Use only characters A-Za-z0-9, no special characters or spaces
DB_PASSWORD=<your-secure-password>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# =============================================================================
# EXTERNAL LIBRARY SETTINGS
# =============================================================================

# Path to your external photo library on the host machine
# Windows example: F:/Photos
# Linux example: /mnt/photos
EXTERNAL_LIB_LOCATION=<path-to-your-photos>

# =============================================================================
# FOLDER ALBUM CREATOR SETTINGS
# Documentation: https://github.com/Salvoxia/immich-folder-album-creator
# =============================================================================

# Internal URL used by helper containers on the compose network
IMMICH_API_URL_INTERNAL=http://immich-server:2283/api/

# Immich API key for the user that owns the external library
# Generate at: Immich Web UI -> Account Settings -> API Keys
IMMICH_FOLDER_ALBUM_CREATOR_API_KEY=<your-api-key>

# Root paths INSIDE the container for the external library
# Comma-separated for multiple paths (e.g., /photos/Person1,/photos/Person2)
IMMICH_FOLDER_ALBUM_CREATOR_ROOT_PATH=/photos

# Number of folder levels to use for album name
# 1 = just folder name (e.g., "Vacation 2024")
# 2 = two levels (e.g., "Person Vacation 2024")
IMMICH_FOLDER_ALBUM_CREATOR_ALBUM_LEVELS=1

# Cron schedule for album sync (default: hourly)
# Format: minute hour day month weekday
IMMICH_FOLDER_ALBUM_CREATOR_CRON=0 * * * *

# Run album creator immediately on container start
IMMICH_FOLDER_ALBUM_CREATOR_RUN_IMMEDIATELY=true
